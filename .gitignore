# PRIVACIDAD DE DATOS: regla cero 
# Cualquier archivo con datos causa-por-causa NO va al repo, sin excepciones.
# una IPP es un identificador unica re-identificable contra el poder judiical de Bs.As.
# por lo tanto cae bajo política de PII aunque no haya nombres

# Registro de causas (entrada del pipeline de Iteración A).
data/raw/*
!data/raw/.gitkeep

# Outputs derivados (se regeneran corriendo el pipeline).
outputs/*
!outputs/.gitkeep

# Indicadores agregados mensuales del juzgado.
# no son  PII (conteos), pero por consistencia con la política se excluyen

data/external/indicadores_*.xlsx

#  datos publicos
!data/external/codificacion-delitos-*.csv

# streamlit
.streamlit/secrets.toml

# Backfills de resoluciones (datos causa-por-causa).
# Excluimos los .xlsx pero SÍ versionamos checksums.json.
data/backfill/*.xlsx
